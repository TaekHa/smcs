# ============================================================
# SMCS Production environment template (Story 4.6)
# Copy to `.env` (gitignored) and fill in real values.
# Generate each base64 secret with:  openssl rand -base64 32
# ============================================================

# --- Postgres + Spring datasource (single source of truth for the db password) ---
# Used by:
#   - postgres service: sets the smcs user password on first init.
#   - backend service: interpolated into SPRING_DATASOURCE_PASSWORD by compose.
POSTGRES_PASSWORD=__CHANGE_ME__

# --- Application secrets (each MUST be openssl rand -base64 32; 32+ bytes after decode) ---
# Backend refuses to start if any of these are missing (CI lesson #3).
SMCS_JWT_SECRET=__CHANGE_ME_base64_32bytes__
SMCS_DATA_KEY=__CHANGE_ME_base64_32bytes__
SMCS_HMAC_KEY=__CHANGE_ME_base64_32bytes__

# --- Host filesystem paths (bind-mounted into the backend container) ---
# Owner MUST be uid 1000 (the non-root smcs user inside the container).
# Example: sudo mkdir -p /data/smcs/files && sudo chown -R 1000:1000 /data/smcs/files
SMCS_FILES_DIR=/data/smcs/files
SMCS_LOGS_DIR=/var/log/smcs

# --- Reports cron (Spring 6-field cron, container TZ=Asia/Seoul) ---
# First production deploy: keep cleanup-cron unreachable (Feb 31) per Story 3.5
# Deviation #8. After ~1 week of stable archives, change to "0 0 3 * * *".
SMCS_REPORTS_DAILY_CRON=0 0 8 * * *
SMCS_REPORTS_WEEKLY_CRON=0 0 8 * * MON
SMCS_REPORTS_CLEANUP_CRON=0 0 5 31 2 *
SMCS_REPORTS_RETENTION_DAYS=90
