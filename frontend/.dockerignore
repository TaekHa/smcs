# Build artifacts — let the container rebuild deterministically.
node_modules/
dist/
coverage/
.vite/

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# VCS
.git/
.gitignore
.gitattributes

# Logs / temp
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
tmp/

# Secrets — never bake into images.
.env
.env.*
*.key
*.pem
*.crt
*.p12
*.jks

# Tests / config not needed for the production bundle.
**/*.test.ts
**/*.test.tsx
vitest.config.ts
